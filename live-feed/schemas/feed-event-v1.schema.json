{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nailinstitute.org/schemas/feed-event-v1.0.0.json",
  "title": "AVE Live Feed Event",
  "description": "Schema for real-time AVE feed events (WebSocket, SSE, REST)",
  "type": "object",
  "required": ["event_id", "event_type", "timestamp", "sequence", "data"],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique event identifier",
      "pattern": "^evt_[0-9]{8}_[0-9]{6}$",
      "examples": ["evt_20250701_001042"]
    },
    "event_type": {
      "type": "string",
      "description": "Type of event",
      "enum": [
        "ave.created",
        "ave.updated",
        "ave.deprecated",
        "ave.status_changed",
        "ave.severity_changed",
        "avss.recalculated",
        "feed.heartbeat"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the event"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing sequence number for ordering and replay"
    },
    "data": {
      "type": "object",
      "description": "Event payload — varies by event_type",
      "properties": {
        "ave_id": {
          "type": "string",
          "pattern": "^AVE-[0-9]{4}-[0-9]{4}$"
        },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "informational"]
        },
        "status": { "type": "string" },
        "avss_base": { "type": "number", "minimum": 0, "maximum": 10 },
        "old_severity": { "type": "string" },
        "new_severity": { "type": "string" },
        "old_status": { "type": "string" },
        "new_status": { "type": "string" },
        "old_avss_base": { "type": "number" },
        "new_avss_base": { "type": "number" },
        "reason": { "type": "string" },
        "diff": {
          "type": "object",
          "description": "Field-level diff for ave.updated events"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Heartbeat timestamp"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Event metadata",
      "properties": {
        "schema_version": { "type": "string" },
        "source": { "type": "string" },
        "region": { "type": "string" }
      }
    }
  }
}
